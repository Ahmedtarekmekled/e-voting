  "description": "Blockchain-based E-Voting System MVP",
  "scripts": {
    "reset": "pwsh -ExecutionPolicy Bypass -File ./reset-and-start.ps1",
    "start": "pwsh -ExecutionPolicy Bypass -File ./reset-and-start.ps1",
